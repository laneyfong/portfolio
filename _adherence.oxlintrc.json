{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Manrope|Playfair Display))/i]",
        "message": "Font not provided by the design system. Available: Manrope, Playfair Display."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|role|tagline|location|background|description|photo|showCTA|onCTAClick|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: name, role, tagline, location, background, description, photo, showCTA, onCTAClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|active|onSelect|key|ref|className|style|children)$/]",
        "message": "<NavPill> doesn't accept that prop. Declared props: items, active, onSelect."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProjectCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:logo|logoAlt|screenshot|caption|captionItalic|layout|href|height|key|ref|className|style|children)$/]",
        "message": "<ProjectCard> doesn't accept that prop. Declared props: logo, logoAlt, screenshot, caption, captionItalic, layout, href, height."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProjectCard'] > JSXAttribute[name.name='layout'] > Literal[value!=/^(?:portrait|landscape)$/]",
        "message": "<ProjectCard> layout must be one of 'portrait' | 'landscape'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "Badge": {
        "replaces": []
      },
      "NavPill": {
        "replaces": []
      },
      "ProjectCard": {
        "replaces": []
      }
    },
    "tokens": [
      "--border-subtle",
      "--color-accent",
      "--color-black",
      "--color-body",
      "--color-dark",
      "--color-ink",
      "--color-muted",
      "--color-nav-active",
      "--color-nav-bg",
      "--color-off-white",
      "--color-secondary",
      "--color-stroke",
      "--color-white",
      "--font-light",
      "--font-medium",
      "--font-regular",
      "--font-sans",
      "--font-serif-italic",
      "--leading-none",
      "--leading-normal",
      "--leading-snug",
      "--radius-full",
      "--radius-lg",
      "--radius-md",
      "--radius-sm",
      "--radius-xl",
      "--radius-xs",
      "--shadow-badge",
      "--shadow-card",
      "--shadow-image-frame",
      "--shadow-inset-circle",
      "--shadow-subtle",
      "--space-1",
